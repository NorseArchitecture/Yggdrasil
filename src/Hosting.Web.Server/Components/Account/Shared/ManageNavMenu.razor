@using Microsoft.AspNetCore.Identity
@using Norse.Identity

@inject SignInManager<NorseUser> SignInManager

<FluentNav>
    <FluentNavItem Href="Account/Manage" Match="NavLinkMatch.All">Profile</FluentNavItem>
    <FluentNavItem Href="Account/Manage/Email">Email</FluentNavItem>
    <FluentNavItem Href="Account/Manage/ChangePassword">Password</FluentNavItem>
    @if (_hasExternalLogins)
    {
        <FluentNavItem Href="Account/Manage/ExternalLogins">External logins</FluentNavItem>
    }
    <FluentNavItem Href="Account/Manage/TwoFactorAuthentication">Two-factor authentication</FluentNavItem>
    <FluentNavItem Href="Account/Manage/Passkeys">Passkeys</FluentNavItem>
    <FluentNavItem Href="Account/Manage/PersonalData">Personal data</FluentNavItem>

</FluentNav>

@code {
    bool _hasExternalLogins;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        _hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
